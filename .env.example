GRADIO_SHARE=false

# =========================================================
# Application
# =========================================================
APP_NAME=pod-zone-21-usine
APP_ENV=development
DEBUG=false
HOST=127.0.0.1
PORT=7861
AUTO_OPEN_BROWSER=true

# =========================================================
# Répertoire principal de travail
# Exemple :
# /Users/ton-user/Library/CloudStorage/GoogleDrive-xxx/Mon Drive/ZONE21/...
# =========================================================
WAREHOUSE_DIR=/Users/gregloupiac/Library/CloudStorage/GoogleDrive-21corestudios@gmail.com/Mon Drive/ZONE21/03_BRANDS/BR-21-WEAR/01_OFFER_CATALOG

# Noms des sous-dossiers métier
RAW_DIR_NAME=01_canva_raw
UPSCALED_DIR_NAME=02_upscaled
FINAL_DIR_NAME=03_final_png
PUBLISHED_DIR_NAME=04_publies

# =========================================================
# Outils système
# =========================================================
GIMP_BIN=/Applications/GIMP.app/Contents/MacOS/gimp
UPSCALE_BIN=/Applications/Upscayl.app/Contents/Resources/bin/upscayl-bin
UPSCALE_MODELS_DIR=/Applications/Upscayl.app/Contents/Resources/models
MAGICK_BIN=magick
RCLONE_BIN=rclone

# =========================================================
# Provider par défaut
# Valeurs possibles : gelato / printify
# =========================================================
DEFAULT_PROVIDER=gelato

# =========================================================
# Gelato
# =========================================================
GELATO_API_KEY=
GELATO_STORE_ID=
GELATO_TEMPLATE_ID=

# =========================================================
# Printify
# =========================================================
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=
PRINTIFY_BLUEPRINT_ID=
PRINTIFY_PRINT_PROVIDER_ID=

# =========================================================
# Google Drive / PyDrive2
# =========================================================
# GOOGLE_DRIVE_CREDENTIALS_FILE=/chemin/vers/mycreds.txt
# GOOGLE_DRIVE_CLIENT_SECRETS_FILE=/chemin/vers/client_secrets.json

# IMPORTANT :
# true  = autorise la mise en lecture publique d'un fichier Drive
# false = interdit ce comportement par défaut
GOOGLE_DRIVE_MAKE_PUBLIC=false
