# =========================================================
# Application
# =========================================================
APP_NAME=pod-zone-21-usine
APP_ENV=development
DEBUG=false
HOST=127.0.0.1
PORT=7861
GRADIO_SHARE=false
AUTO_OPEN_BROWSER=true

# =========================================================
# Répertoire principal de travail
# Doit pointer vers le dossier racine métier contenant les collections.
# Exemple macOS :
# /Users/your-user/Library/CloudStorage/GoogleDrive-xxx/Mon Drive/ZONE21/03_BRANDS/BR-21-WEAR/01_OFFER_CATALOG
# =========================================================
WAREHOUSE_DIR=

# Noms des sous-dossiers métier
RAW_DIR_NAME=01_canva_raw
UPSCALED_DIR_NAME=02_upscaled
FINAL_DIR_NAME=03_final_png
PUBLISHED_DIR_NAME=04_publies

# =========================================================
# Outils système
# Utiliser soit un nom de binaire présent dans le PATH,
# soit un chemin absolu adapté au poste local.
# =========================================================
GIMP_BIN=gimp
UPSCALE_BIN=upscayl-bin
UPSCALE_MODELS_DIR=
MAGICK_BIN=magick
RCLONE_BIN=rclone

# =========================================================
# Provider par défaut
# Valeurs possibles : gelato / printify
# =========================================================
DEFAULT_PROVIDER=gelato

# =========================================================
# Gelato
# =========================================================
GELATO_API_KEY=
GELATO_STORE_ID=
GELATO_TEMPLATE_ID=

# =========================================================
# Printify
# =========================================================
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=
PRINTIFY_BLUEPRINT_ID=1
PRINTIFY_PRINT_PROVIDER_ID=1

# =========================================================
# Google Drive / PyDrive2
# Renseigner ces chemins uniquement si la synchronisation Drive est utilisée.
# =========================================================
GOOGLE_DRIVE_CREDENTIALS_FILE=
GOOGLE_DRIVE_CLIENT_SECRETS_FILE=

# IMPORTANT :
# true  = autorise la mise en lecture publique d'un fichier Drive
# false = interdit ce comportement par défaut
GOOGLE_DRIVE_MAKE_PUBLIC=false
