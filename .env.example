# ==========================================
# CONFIGURATION GLOBALE
# ==========================================
APP_NAME=pod-zone-21-usine
APP_ENV=development
DEBUG=1
HOST=127.0.0.1
PORT=7861

# SECURITE : Désactivé par défaut pour éviter d'exposer l'usine sur internet via Gradio
GRADIO_SHARE=0
AUTO_OPEN_BROWSER=1

# ==========================================
# CHEMINS LOCAUX & BINAIRES (macOS par défaut)
# ==========================================
WAREHOUSE_DIR=./workspace
GIMP_BIN=/Applications/GIMP.app/Contents/MacOS/gimp
UPSCALE_BIN=/Applications/Upscayl.app/Contents/Resources/bin/upscayl-bin
UPSCALE_MODELS_DIR=/Applications/Upscayl.app/Contents/Resources/models
MAGICK_BIN=magick
RCLONE_BIN=rclone

# ==========================================
# PROVIDERS POD & API (Gelato / Printify)
# ==========================================
DEFAULT_PROVIDER=gelato

# Gelato
GELATO_API_KEY=your_gelato_api_key_here
GELATO_STORE_ID=your_gelato_store_id
GELATO_TEMPLATE_ID=your_gelato_template_id

# Printify
PRINTIFY_API_TOKEN=your_printify_token_here
PRINTIFY_SHOP_ID=your_printify_shop_id
PRINTIFY_BLUEPRINT_ID=your_printify_blueprint_id
PRINTIFY_PRINT_PROVIDER_ID=your_printify_provider_id
